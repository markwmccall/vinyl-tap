[Unit]
Description=Vinyl Emulator Web UI
After=network-online.target
Wants=network-online.target

[Service]
ExecStart=authbind --deep /home/pi/vinyl-emulator/.venv/bin/python3 /home/pi/vinyl-emulator/app.py --host 0.0.0.0 --port 80
WorkingDirectory=/home/pi/vinyl-emulator
Restart=on-failure
RestartSec=5
KillMode=process
MemoryLimit=256M
User=pi

[Install]
WantedBy=multi-user.target
